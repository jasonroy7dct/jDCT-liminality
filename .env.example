# Firebase: for local dev, add "localhost" under Authentication → Settings → Authorized domains
# (Firebase Console). Otherwise Google sign-in shows auth/unauthorized-domain.

# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Plaid Credentials
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_CLIENT_NAME=Liminality

# Server
PORT=3000

# FX (demo / display — override for your scenario)
USD_TWD_RATE=32.85
USD_HKD_RATE=7.8
USD_JPY_RATE=150

# Gemini API Key
GEMINI_API_KEY=
